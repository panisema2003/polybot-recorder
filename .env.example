# Copy to .env and fill in. Phase 1 (read-only) needs NOTHING here —
# the public Gamma/CLOB read endpoints require no auth.
#
# These are placeholders for Phase 2 (live trading). Do NOT commit .env.

# --- Polymarket trading credentials (Phase 2 only) ---
# Your Polygon wallet private key (the funded trading wallet). KEEP SECRET.
# POLY_PRIVATE_KEY=
# Polymarket CLOB API credentials, derived from the wallet via py-clob-client.
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
# Funder/proxy address (Polymarket proxy wallet that holds USDC), if used.
# POLY_FUNDER_ADDRESS=

# --- Optional overrides ---
# POLYBOT_CONFIG=config.yaml
# POLYBOT_DB=data/polybot.db
# POLYBOT_LOG_LEVEL=INFO
